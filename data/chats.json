        "user_id": 3,
        "message": "{\"sessionId\":\"session-1773349392119-odvru2\",\"modelId\":\"lanna\",\"title\":\"Chat Baru\",\"sessionCreatedAt\":\"2026-03-12T21:03:12.119Z\",\"updatedAt\":\"2026-03-12T21:54:54.364Z\",\"userMessageId\":\"message-1773349422101-s7d1i6\",\"userTimestamp\":\"2026-03-12T21:03:42.101Z\",\"userMessage\":\"hi\"}",
