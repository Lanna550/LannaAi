        "user_id": 3,
        "message": "{\"sessionId\":\"session-1773358164175-vp052a\",\"modelId\":\"furina\",\"title\":\"Haii\",\"sessionCreatedAt\":\"2026-03-12T23:29:24.175Z\",\"updatedAt\":\"2026-03-12T23:35:55.941Z\",\"userMessageId\":\"message-1773358555941-netfue\",\"userTimestamp\":\"2026-03-12T23:35:55.941Z\",\"userMessage\":\"[Membagikan file: miku.jpg]\"}",
        "response": "{\"assistantMessageId\":null,\"assistantTimestamp\":\"2026-03-12T23:35:55.941Z\",\"assistantMessage\":\"\",\"preview\":\"[Membagikan file: miku.jpg]\",\"updatedAt\":\"2026-03-12T23:35:55.941Z\"}",
