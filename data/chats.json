      {
        "id": 569,
        "user_id": 3,
        "message": "{\"sessionId\":\"session-1773358164175-vp052a\",\"modelId\":\"furina\",\"title\":\"Haii\",\"sessionCreatedAt\":\"2026-03-12T23:29:24.175Z\",\"updatedAt\":\"2026-03-12T23:35:55.941Z\",\"userMessageId\":\"message-1773358189259-yss090\",\"userTimestamp\":\"2026-03-12T23:29:49.259Z\",\"userMessage\":\"hi\"}",
        "response": "{\"assistantMessageId\":\"message-1773358196164-nltwwr\",\"assistantTimestamp\":\"2026-03-12T23:29:56.164Z\",\"assistantMessage\":\"Oh?\\n\\nSebuah kekeh yang ringan. Apa gerangan yang memercikkan riak kegembiraan di dalam dirimu itu? Ceritakanlah, jika kau berkenan. Aku selalu tertarik pada melodi hati yang tak terduga.\",\"preview\":\"[Membagikan file: miku.jpg]\",\"updatedAt\":\"2026-03-12T23:35:55.941Z\"}",
        "created_at": "2026-03-12T23:29:49.000Z"
